{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2022",
    "skipLibCheck": true
  },
  "include": ["src/git-parse.js", "src/classify.js", "src/gdsx-cli.js", "src/gdsx-lib.js"],
  "exclude": ["dist", "node_modules", "test"]
}
