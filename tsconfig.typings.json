{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2022",
    "skipLibCheck": true
  },
  "include": [
    "gdsx",
    "gdsx-lib.js"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "test"
  ]
}
